---
import { IconMail, IconPhone, IconMapPin, IconClock, IconSend } from '@tabler/icons-react';
---

<section id="contacto">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Contacto</span>
      <h2 class="section-title">Hablemos de tu <span class="gradient-text">proyecto</span></h2>
      <p class="section-desc">Cuéntanos qué necesitas y te enviaremos una propuesta personalizada.</p>
    </div>

    <div class="contact-grid">
      <form class="contact-form" onsubmit="return handleSubmit(event)">
        <div class="form-row">
          <div class="form-group">
            <label for="name" class="form-label">Nombre completo</label>
            <input type="text" id="name" required class="form-input" placeholder="Tu nombre" />
          </div>
          <div class="form-group">
            <label for="email" class="form-label">Correo electrónico</label>
            <input type="email" id="email" required class="form-input" placeholder="tu@correo.com" />
          </div>
        </div>
        <div class="form-group">
          <label for="phone" class="form-label">Teléfono</label>
          <input type="tel" id="phone" required class="form-input" placeholder="123 4513541" />
        </div>
        <div class="form-group">
          <label for="service" class="form-label">Servicio de interés</label>
          <select id="service" class="form-select">
            <option value="">Selecciona un servicio</option>
            <option value="mantenimiento">Mantenimiento de equipos</option>
            <option value="redes">Instalación de redes</option>
            <option value="cableado">Cableado estructurado</option>
            <option value="configuracion">Configuración de routers/switches</option>
            <option value="soporte">Soporte técnico</option>
            <option value="wifi">Redes inalámbricas</option>
            <option value="otro">Otro</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message" class="form-label">Mensaje</label>
          <textarea id="message" rows="4" required class="form-textarea" placeholder="Cuéntanos sobre tu proyecto..."></textarea>
        </div>
        <button type="submit" class="form-btn">
          Enviar mensaje
          <IconSend />
        </button>
        <p class="form-feedback" id="form-feedback"></p>
      </form>

      <div class="contact-info">
        <div class="contact-info-list">
          <div class="contact-info-item">
            <div class="contact-info-icon primary"><IconPhone /></div>
            <div>
              <h3 class="contact-info-label">Teléfono</h3>
              <p class="contact-info-value">+57 123 4513541</p>
              <p class="contact-info-value">+57 123 4513541</p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon accent"><IconMail /></div>
            <div>
              <h3 class="contact-info-label">Correo electrónico</h3>
              <p class="contact-info-value">contacto@sistek.com.co</p>
              <p class="contact-info-value">soporte@sistek.com.co</p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon primary"><IconMapPin /></div>
            <div>
              <h3 class="contact-info-label">Ubicación</h3>
              <p class="contact-info-value">Calle 41, Cra 31 #00</p>
              <p class="contact-info-value">Cali, Valle del Cauca</p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon accent"><IconClock /></div>
            <div>
              <h3 class="contact-info-label">Horario</h3>
              <p class="contact-info-value">Lun - Vie: 8:00 - 18:00</p>
              <p class="contact-info-value">Sáb: 9:00 - 13:00</p>
            </div>
          </div>
        </div>

        <div class="contact-map">
          <div class="contact-map-inner">
            <div class="contact-map-content">
              <IconMapPin />
              <p class="contact-map-title">Mapa interactivo</p>
              <p class="contact-map-sub">Calle 41, Cra 31 #00, Cali</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function handleSubmit(event) {
    event.preventDefault();
    const feedback = document.getElementById('form-feedback');
    feedback.textContent = 'Gracias por contactarnos. Te responderemos a la brevedad.';
    feedback.className = 'form-feedback success';
    event.target.reset();
    setTimeout(() => {
      feedback.textContent = '';
      feedback.className = 'form-feedback';
    }, 5000);
    return false;
  }
</script>
