---
import { IconBrandTwitter, IconBrandLinkedin, IconBrandInstagram, IconBrandFacebook, IconArrowUp } from '@tabler/icons-react';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="#" class="footer-logo">
          <div class="footer-logo-icon">S</div>
          <span class="footer-logo-text">Sistek<span class="gradient-text">Pro</span></span>
        </a>
        <p class="footer-desc">
          Infraestructura TI, redes empresariales y soporte técnico profesional. Transformamos tu tecnología para impulsar tu negocio.
        </p>
        <div class="footer-social">
          <a href="#" aria-label="Twitter"><IconBrandTwitter /></a>
          <a href="#" aria-label="LinkedIn"><IconBrandLinkedin /></a>
          <a href="#" aria-label="Instagram"><IconBrandInstagram /></a>
          <a href="#" aria-label="Facebook"><IconBrandFacebook /></a>
        </div>
      </div>

      <div>
        <h3 class="footer-heading">Servicios</h3>
        <ul class="footer-links">
          <li><a href="#servicios">Mantenimiento de equipos</a></li>
          <li><a href="#servicios">Instalación de redes</a></li>
          <li><a href="#servicios">Cableado estructurado</a></li>
          <li><a href="#servicios">Configuración de redes</a></li>
          <li><a href="#servicios">Redes inalámbricas</a></li>
          <li><a href="#servicios">Soporte técnico</a></li>
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">Empresa</h3>
        <ul class="footer-links">
          <li><a href="#about">Sobre nosotros</a></li>
          <li><a href="#beneficios">Beneficios</a></li>
          <li><a href="#faq">Preguntas frecuentes</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">Contacto directo</h3>
        <ul class="footer-contact-list">
          <li class="footer-contact-item">
            <span class="footer-contact-label">Teléfono</span>
            +57 123 4513541
          </li>
          <li class="footer-contact-item">
            <span class="footer-contact-label">Email</span>
            contacto@sistek.com.co
          </li>
          <li class="footer-contact-item">
            <span class="footer-contact-label">WhatsApp</span>
            +57 123 4513541
          </li>
          <li class="footer-contact-item">
            <span class="footer-contact-label">Ubicación</span>
            Calle 41, Cra 31 #00, Cali
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {new Date().getFullYear()} Sistek. Todos los derechos reservados.</p>
      <div class="footer-legal">
        <a href="/privacidad" target="_blank">Aviso de privacidad</a>
        <a href="/terminos" target="_blank">Términos y condiciones</a>
      </div>
      <a href="#" class="back-to-top" aria-label="Volver arriba"><IconArrowUp /></a>
    </div>
  </div>
</footer>
