---
import { IconArrowRight, IconHeadset } from '@tabler/icons-react';
---

<section class="cta-section">
  <div class="cta-bg"></div>
  <div class="cta-grid-bg"></div>
  <div class="cta-card">
    <div class="cta-card-inner">
      <h2 class="cta-title">
        ¿Listo para mejorar tu <span class="gradient-text">infraestructura TI</span>?
      </h2>
      <p class="cta-desc">
        Solicita una cotización sin compromiso. Te asesoraremos para encontrar la solución tecnológica que mejor se adapte a tus necesidades.
      </p>
      <div class="cta-actions">
        <a href="#contacto" class="btn-primary glow">
          Solicitar cotización
          <IconArrowRight />
        </a>
        <a href="tel:+571234513541" class="btn-secondary">
          <IconHeadset />
          Llamar ahora
        </a>
      </div>
      <div class="cta-features">
        <span>Sin compromiso</span>
        <span>•</span>
        <span>Atención personalizada</span>
        <span>•</span>
        <span>Soluciones a tu medida</span>
      </div>
    </div>
  </div>
</section>
